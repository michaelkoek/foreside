{
  "name": "gateway",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "generate": "protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./src/proto --ts_proto_opt=outputServices=grpc-js,esModuleInterop=true,snakeToCamel=false -I ../proto ../proto/beer.proto ../proto/order.proto",
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@grpc/grpc-js": "^1.11.1",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.6.1",
    "typescript": "^5.6.0"
  }
}
